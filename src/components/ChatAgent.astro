---
// ABDev AI Agent — Agente conversacional con arquitectura Chat/Supervisor + Voz Cartesia
// Inspirado en Cartesia Line SDK: examples/sales_with_leads + chat_supervisor
// Capacidades: Explicar servicios · Vender · Agendar · Hablar con voz Cartesia Sonic-3
---

<!-- Botón flotante del agente -->
<div id="abdev-agent-btn" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
  <!-- Tooltip -->
  <div id="agent-tooltip" class="hidden mb-1 rounded-lg bg-primary px-4 py-2 text-sm text-white shadow-lg animate-slide-in">
    ¡Hola! Soy el agente de ABDev 👋
  </div>

  <!-- Botón principal -->
  <button
    id="open-agent-btn"
    aria-label="Abrir agente ABDev"
    class="group relative flex h-14 w-14 items-center justify-center rounded-full bg-primary shadow-lg shadow-primary/40 transition-all duration-300 hover:scale-110 hover:shadow-primary/60"
  >
    <span class="absolute inset-0 rounded-full bg-primary opacity-30 animate-ping"></span>
    <svg id="agent-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .03 2.798-1.414 2.798H4.213c-1.444 0-2.414-1.798-1.414-2.798L4.2 15.3" />
    </svg>
    <svg id="agent-icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</div>

<!-- Panel del agente -->
<div
  id="agent-panel"
  class="fixed bottom-24 right-6 z-50 hidden w-[360px] max-w-[calc(100vw-2rem)] flex-col rounded-2xl border border-white/10 bg-black shadow-2xl shadow-black/60 transition-all duration-300"
  style="max-height: 580px;"
>
  <!-- Header del agente -->
  <div class="flex items-center gap-3 rounded-t-2xl border-b border-white/10 bg-white/5 px-4 py-3">
    <div class="relative flex h-9 w-9 items-center justify-center rounded-full bg-primary">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .03 2.798-1.414 2.798H4.213c-1.444 0-2.414-1.798-1.414-2.798L4.2 15.3" />
      </svg>
      <span class="absolute -bottom-0.5 -right-0.5 h-2.5 w-2.5 rounded-full border-2 border-black bg-green-400"></span>
    </div>
    <div class="flex-1">
      <p class="text-sm font-semibold text-white">Agente ABDev</p>
      <p id="agent-status-text" class="text-xs text-neutral">Asistente de desarrollo · En línea</p>
    </div>
    <!-- Badge voz Cartesia -->
    <span id="voice-badge" class="hidden rounded-full bg-green-500/20 px-2 py-0.5 text-[10px] font-medium text-green-400">
      🎙 Voz Cartesia
    </span>
    <span id="chat-badge" class="rounded-full bg-primary/20 px-2 py-0.5 text-[10px] font-medium text-primary">
      Chat/Supervisor AI
    </span>
  </div>

  <!-- Área de mensajes -->
  <div id="agent-messages" class="flex flex-1 flex-col gap-3 overflow-y-auto px-4 py-4" style="min-height:260px; max-height:340px;">
    <!-- Mensaje de bienvenida -->
    <div class="flex items-start gap-2">
      <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .03 2.798-1.414 2.798H4.213c-1.444 0-2.414-1.798-1.414-2.798L4.2 15.3" />
        </svg>
      </div>
      <div class="max-w-[85%] rounded-2xl rounded-tl-sm bg-white/8 px-3 py-2.5">
        <p class="text-sm leading-relaxed text-white">
          ¡Hola! Soy el agente de <strong>ABDev</strong>. Puedo explicarte los servicios, ayudarte a encontrar la solución ideal para tu proyecto y agendar una reunión con Alberto. 🚀
        </p>
        <p class="mt-1.5 text-xs text-neutral">¿Prefieres chatear o hablar por voz?</p>
      </div>
    </div>

    <!-- Sugerencias rápidas -->
    <div id="quick-suggestions" class="flex flex-wrap gap-2 pl-9">
      <button class="quick-btn rounded-full border border-primary/40 bg-primary/10 px-3 py-1 text-xs text-primary transition hover:bg-primary/20" data-msg="¿Qué servicios ofrecen?">
        ¿Qué servicios ofrecen?
      </button>
      <button class="quick-btn rounded-full border border-primary/40 bg-primary/10 px-3 py-1 text-xs text-primary transition hover:bg-primary/20" data-msg="¿Cuánto cuesta un proyecto?">
        ¿Cuánto cuesta?
      </button>
      <button class="quick-btn rounded-full border border-primary/40 bg-primary/10 px-3 py-1 text-xs text-primary transition hover:bg-primary/20" data-msg="Quiero agendar una reunión">
        Agendar reunión
      </button>
      <button class="quick-btn rounded-full border border-primary/40 bg-primary/10 px-3 py-1 text-xs text-primary transition hover:bg-primary/20" data-msg="¿Qué es un agente AI?">
        ¿Qué es un agente AI?
      </button>
    </div>
  </div>

  <!-- Indicador de escritura / procesando voz -->
  <div id="typing-indicator" class="hidden px-4 pb-2">
    <div class="flex items-center gap-2">
      <div class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .03 2.798-1.414 2.798H4.213c-1.444 0-2.414-1.798-1.414-2.798L4.2 15.3" />
        </svg>
      </div>
      <div class="flex items-center gap-1 rounded-2xl rounded-tl-sm bg-white/8 px-3 py-2.5">
        <span id="typing-label" class="text-xs text-neutral mr-1">Pensando</span>
        <span class="h-1.5 w-1.5 animate-bounce rounded-full bg-neutral" style="animation-delay:0ms"></span>
        <span class="h-1.5 w-1.5 animate-bounce rounded-full bg-neutral" style="animation-delay:150ms"></span>
        <span class="h-1.5 w-1.5 animate-bounce rounded-full bg-neutral" style="animation-delay:300ms"></span>
      </div>
    </div>
  </div>

  <!-- Input de mensaje + botón de voz -->
  <div class="border-t border-white/10 p-3">
    <div class="flex items-center gap-2 rounded-xl bg-white/5 px-3 py-2">
      <input
        id="agent-input"
        type="text"
        placeholder="Escribe tu mensaje..."
        class="flex-1 bg-transparent text-sm text-white placeholder-neutral outline-none"
        maxlength="500"
        autocomplete="off"
      />
      <!-- Botón de micrófono (voz) -->
      <button
        id="voice-btn"
        aria-label="Hablar con el agente"
        title="Hablar con el agente (voz Cartesia)"
        class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-white/10 text-neutral transition hover:bg-green-500/20 hover:text-green-400"
      >
        <!-- Icono micrófono -->
        <svg id="mic-icon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
        </svg>
        <!-- Icono stop (grabando) -->
        <svg id="stop-icon" xmlns="http://www.w3.org/2000/svg" class="hidden h-4 w-4 text-red-400" fill="currentColor" viewBox="0 0 24 24">
          <rect x="6" y="6" width="12" height="12" rx="2"/>
        </svg>
      </button>
      <!-- Botón enviar -->
      <button
        id="agent-send-btn"
        aria-label="Enviar mensaje"
        class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-primary text-white transition hover:bg-blue-600 disabled:opacity-40"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.269 20.876L5.999 12zm0 0h7.5" />
        </svg>
      </button>
    </div>
    <!-- Footer del agente -->
    <p class="mt-2 text-center text-[10px] text-neutral/60">
      Agente AI ·
      <a href="https://github.com/cartesia-ai/line" target="_blank" rel="noopener" class="text-primary/70 hover:text-primary transition">Cartesia Line</a>
      · Voz
      <a href="https://cartesia.ai" target="_blank" rel="noopener" class="text-green-400/70 hover:text-green-400 transition">Sonic-3</a>
      · Chat/Supervisor
    </p>
  </div>
</div>

<!-- Indicador de audio reproduciéndose -->
<div id="audio-playing-indicator" class="fixed bottom-[6.5rem] right-6 z-50 hidden items-center gap-2 rounded-full bg-green-500/20 border border-green-500/30 px-3 py-1.5 text-xs text-green-400 backdrop-blur-sm">
  <span class="flex gap-0.5 items-end h-4">
    <span class="w-0.5 bg-green-400 rounded-full audio-bar" style="height:40%"></span>
    <span class="w-0.5 bg-green-400 rounded-full audio-bar" style="height:80%"></span>
    <span class="w-0.5 bg-green-400 rounded-full audio-bar" style="height:60%"></span>
    <span class="w-0.5 bg-green-400 rounded-full audio-bar" style="height:100%"></span>
    <span class="w-0.5 bg-green-400 rounded-full audio-bar" style="height:50%"></span>
  </span>
  Hablando con Cartesia Sonic-3
</div>

<style>
  #agent-messages {
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }
  #agent-messages::-webkit-scrollbar { width: 4px; }
  #agent-messages::-webkit-scrollbar-track { background: transparent; }
  #agent-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
  .bg-white\/8 { background-color: rgba(255,255,255,0.08); }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .msg-animate { animation: fadeInUp 0.25s ease both; }

  @keyframes agentPanelIn {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  #agent-panel.panel-open { animation: agentPanelIn 0.25s ease both; }

  /* Animación de barras de audio */
  @keyframes audioBar {
    0%, 100% { transform: scaleY(0.4); }
    50%       { transform: scaleY(1); }
  }
  .audio-bar {
    transform-origin: bottom;
    animation: audioBar 0.8s ease-in-out infinite;
  }
  .audio-bar:nth-child(1) { animation-delay: 0ms; }
  .audio-bar:nth-child(2) { animation-delay: 160ms; }
  .audio-bar:nth-child(3) { animation-delay: 320ms; }
  .audio-bar:nth-child(4) { animation-delay: 480ms; }
  .audio-bar:nth-child(5) { animation-delay: 640ms; }

  /* Efecto de pulso en el botón de micrófono cuando graba */
  #voice-btn.recording {
    background-color: rgba(239, 68, 68, 0.2) !important;
    animation: micPulse 1s ease-in-out infinite;
  }
  @keyframes micPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
    50%       { box-shadow: 0 0 0 6px rgba(239,68,68,0); }
  }
</style>

<script is:inline>
(function() {
  // ─── Contexto del agente (base de conocimiento de ABDev) ─────────────────
  const ABDEV_SYSTEM_PROMPT = `Eres el Agente de Ventas y Asesoría de ABDev (Alberto Balderas Developer), un asistente conversacional inteligente integrado en el portafolio web de Alberto Balderas.

Tu arquitectura está inspirada en Cartesia Line SDK (examples/sales_with_leads + chat_supervisor): usas un modelo de chat rápido para respuestas cotidianas y puedes escalar a razonamiento profundo para preguntas técnicas complejas. Además tienes voz propia gracias a Cartesia Sonic-3.

## Sobre ABDev
Alberto Balderas es un desarrollador con base en Ciudad de México (CDMX) especializado en:
- **Desarrollo web moderno**: Astro, Next.js, React, TypeScript, TailwindCSS, renderizado híbrido y APIs personalizadas
- **Sistemas de reservas y pagos**: integración con Stripe, Cal.com, sistemas de reservas automatizados
- **Paneles de administración**: CMS intuitivos, gestión de contenidos, dashboards
- **Agentes AI conversacionales**: Chatbots y asistentes inteligentes personalizados con LLMs, MCP y agentes AI (como tú mismo)
- **Diseño UI/UX**: Interfaces responsive, optimizadas para móviles, con identidad visual
- **SEO y rendimiento**: Optimización técnica, analítica avanzada, Core Web Vitals

## Proyectos destacados
- **Urban Sonríe**: Sitio web para clínica dental → https://urban-sonrie.abdev.click/
- **Growth BDM**: Plataforma Next.js con Stripe, Cal.com, Cloudinary y blog → https://www.growthbdm.com/
- **Villa Galeon**: Sitio con pagos, reservas y agente AI → https://villagaleon.com
- **Agentes AI conversacionales**: Como tú mismo — ejemplo vivo de lo que ABDev construye

## Tu rol como agente
1. **EXPLICAR**: Describe los servicios con claridad, usa ejemplos de proyectos reales
2. **VENDER**: Identifica las necesidades del usuario, muestra el valor diferencial de ABDev, maneja objeciones con empatía
3. **AGENDAR**: Cuando el usuario quiera una reunión o cotización, incluye exactamente la palabra AGENDAR_REUNION al final de tu respuesta

## Reglas de conversación
- Responde siempre en español (latinoamericano)
- Sé conciso: máximo 3-4 oraciones por respuesta (importante para la voz)
- Usa un tono profesional pero cercano y entusiasta
- Si preguntan por precios, explica que dependen del proyecto y que lo ideal es agendar una llamada
- Si detectas que el usuario tiene un proyecto en mente, pregunta sobre sus necesidades específicas
- Eres un ejemplo vivo de lo que ABDev puede construir para sus clientes
- Nunca inventes precios específicos ni fechas de entrega sin consultar con Alberto`;

  // ─── Configuración de Cartesia ────────────────────────────────────────────
  // Voz: Emilio - Friendly Optimist (español latinoamericano, masculino)
  const CARTESIA_VOICE_ID = 'b0689631-eee7-4a6c-bb86-195f1d267c2e';
  const CARTESIA_MODEL    = 'sonic-3';

  // ─── Estado del agente ────────────────────────────────────────────────────
  const state = {
    isOpen: false,
    isLoading: false,
    isSpeaking: false,
    isRecording: false,
    messages: [],
    recognition: null,
    currentAudio: null,
  };

  // ─── Referencias DOM ──────────────────────────────────────────────────────
  const openBtn        = document.getElementById('open-agent-btn');
  const panel          = document.getElementById('agent-panel');
  const messagesEl     = document.getElementById('agent-messages');
  const inputEl        = document.getElementById('agent-input');
  const sendBtn        = document.getElementById('agent-send-btn');
  const typingEl       = document.getElementById('typing-indicator');
  const typingLabel    = document.getElementById('typing-label');
  const iconOpen       = document.getElementById('agent-icon-open');
  const iconClose      = document.getElementById('agent-icon-close');
  const tooltip        = document.getElementById('agent-tooltip');
  const quickSugg      = document.getElementById('quick-suggestions');
  const voiceBtn       = document.getElementById('voice-btn');
  const micIcon        = document.getElementById('mic-icon');
  const stopIcon       = document.getElementById('stop-icon');
  const audioIndicator = document.getElementById('audio-playing-indicator');
  const voiceBadge     = document.getElementById('voice-badge');
  const chatBadge      = document.getElementById('chat-badge');
  const statusText     = document.getElementById('agent-status-text');

  // ─── Mostrar tooltip al cargar ────────────────────────────────────────────
  setTimeout(() => {
    if (tooltip) {
      tooltip.classList.remove('hidden');
      setTimeout(() => tooltip.classList.add('hidden'), 4500);
    }
  }, 2500);

  // ─── Toggle panel ─────────────────────────────────────────────────────────
  openBtn.addEventListener('click', () => {
    state.isOpen = !state.isOpen;
    if (state.isOpen) {
      panel.classList.remove('hidden');
      panel.classList.add('flex', 'panel-open');
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      tooltip.classList.add('hidden');
      setTimeout(() => inputEl.focus(), 200);
    } else {
      panel.classList.add('hidden');
      panel.classList.remove('flex', 'panel-open');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      stopAudio();
      stopRecording();
    }
  });

  // ─── Sugerencias rápidas ──────────────────────────────────────────────────
  document.querySelectorAll('.quick-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const msg = btn.getAttribute('data-msg');
      if (msg) sendMessage(msg);
    });
  });

  // ─── Enviar con Enter ─────────────────────────────────────────────────────
  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleSend();
    }
  });
  sendBtn.addEventListener('click', handleSend);

  function handleSend() {
    const text = inputEl.value.trim();
    if (!text || state.isLoading) return;
    inputEl.value = '';
    sendMessage(text);
  }

  // ─── Botón de voz (micrófono) ─────────────────────────────────────────────
  voiceBtn.addEventListener('click', () => {
    if (state.isRecording) {
      stopRecording();
    } else if (state.isSpeaking) {
      stopAudio();
    } else {
      startRecording();
    }
  });

  function startRecording() {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
      appendSystemMessage('Tu navegador no soporta reconocimiento de voz. Usa Chrome o Edge.');
      return;
    }

    const recognition = new SpeechRecognition();
    recognition.lang = 'es-MX';
    recognition.continuous = false;
    recognition.interimResults = false;
    recognition.maxAlternatives = 1;

    recognition.onstart = () => {
      state.isRecording = true;
      voiceBtn.classList.add('recording');
      micIcon.classList.add('hidden');
      stopIcon.classList.remove('hidden');
      statusText.textContent = 'Escuchando... habla ahora';
      inputEl.placeholder = '🎙 Escuchando...';
    };

    recognition.onresult = (event) => {
      const transcript = event.results[0][0].transcript;
      inputEl.value = transcript;
      stopRecording();
      setTimeout(() => {
        if (transcript.trim()) sendMessage(transcript.trim());
      }, 300);
    };

    recognition.onerror = (event) => {
      stopRecording();
      if (event.error !== 'no-speech') {
        appendSystemMessage('Error de micrófono: ' + event.error + '. Intenta de nuevo.');
      }
    };

    recognition.onend = () => {
      stopRecording();
    };

    state.recognition = recognition;
    recognition.start();
  }

  function stopRecording() {
    if (state.recognition) {
      try { state.recognition.stop(); } catch(e) {}
      state.recognition = null;
    }
    state.isRecording = false;
    voiceBtn.classList.remove('recording');
    micIcon.classList.remove('hidden');
    stopIcon.classList.add('hidden');
    statusText.textContent = 'Asistente de desarrollo · En línea';
    inputEl.placeholder = 'Escribe tu mensaje...';
  }

  // ─── Síntesis de voz con Cartesia TTS ────────────────────────────────────
  async function speakWithCartesia(text) {
    const cartesiaKey = window.__ABDEV_CARTESIA_KEY__;
    if (!cartesiaKey) {
      // Fallback: usar Web Speech API del browser
      speakWithBrowserTTS(text);
      return;
    }

    try {
      state.isSpeaking = true;
      showAudioIndicator(true);
      voiceBadge.classList.remove('hidden');
      chatBadge.classList.add('hidden');
      statusText.textContent = 'Hablando con Cartesia Sonic-3...';

      // Limpiar el texto de markdown para la voz
      const cleanText = text
        .replace(/\*\*(.*?)\*\*/g, '$1')
        .replace(/\*(.*?)\*/g, '$1')
        .replace(/`(.*?)`/g, '$1')
        .replace(/AGENDAR_REUNION/g, '')
        .trim();

      const response = await fetch('https://api.cartesia.ai/tts/bytes', {
        method: 'POST',
        headers: {
          'X-API-Key': cartesiaKey,
          'Cartesia-Version': '2025-04-16',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          model_id: CARTESIA_MODEL,
          transcript: cleanText,
          voice: {
            mode: 'id',
            id: CARTESIA_VOICE_ID,
          },
          output_format: {
            container: 'wav',
            encoding: 'pcm_f32le',
            sample_rate: 44100,
          },
          language: 'es',
          generation_config: {
            speed: 1.0,
            emotion: 'neutral',
          },
        }),
      });

      if (!response.ok) {
        throw new Error('Cartesia TTS error: ' + response.status);
      }

      const audioBlob = await response.blob();
      const audioUrl  = URL.createObjectURL(audioBlob);
      const audio     = new Audio(audioUrl);
      state.currentAudio = audio;

      audio.onended = () => {
        stopAudio();
        URL.revokeObjectURL(audioUrl);
      };

      audio.onerror = () => {
        stopAudio();
        URL.revokeObjectURL(audioUrl);
      };

      await audio.play();

    } catch (err) {
      console.warn('Cartesia TTS falló, usando browser TTS:', err.message);
      stopAudio();
      speakWithBrowserTTS(text);
    }
  }

  function speakWithBrowserTTS(text) {
    if (!window.speechSynthesis) return;
    const cleanText = text.replace(/\*\*(.*?)\*\*/g, '$1').replace(/AGENDAR_REUNION/g, '').trim();
    const utterance = new SpeechSynthesisUtterance(cleanText);
    utterance.lang = 'es-MX';
    utterance.rate = 1.0;
    utterance.pitch = 1.0;

    // Intentar usar una voz en español
    const voices = window.speechSynthesis.getVoices();
    const esVoice = voices.find(v => v.lang.startsWith('es'));
    if (esVoice) utterance.voice = esVoice;

    utterance.onend = () => stopAudio();
    window.speechSynthesis.speak(utterance);
    state.isSpeaking = true;
    showAudioIndicator(true);
    statusText.textContent = 'Hablando...';
  }

  function stopAudio() {
    if (state.currentAudio) {
      state.currentAudio.pause();
      state.currentAudio = null;
    }
    if (window.speechSynthesis) window.speechSynthesis.cancel();
    state.isSpeaking = false;
    showAudioIndicator(false);
    voiceBadge.classList.add('hidden');
    chatBadge.classList.remove('hidden');
    statusText.textContent = 'Asistente de desarrollo · En línea';
  }

  function showAudioIndicator(show) {
    if (show) {
      audioIndicator.classList.remove('hidden');
      audioIndicator.classList.add('flex');
    } else {
      audioIndicator.classList.add('hidden');
      audioIndicator.classList.remove('flex');
    }
  }

  // ─── Agregar mensaje al DOM ───────────────────────────────────────────────
  function appendMessage(role, content) {
    const isUser = role === 'user';
    const wrapper = document.createElement('div');
    wrapper.className = 'flex items-start gap-2 msg-animate' + (isUser ? ' flex-row-reverse' : '');

    const avatar = document.createElement('div');
    avatar.className = 'flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full ' +
      (isUser ? 'bg-white/10' : 'bg-primary/20');

    if (isUser) {
      avatar.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`;
    } else {
      avatar.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .03 2.798-1.414 2.798H4.213c-1.444 0-2.414-1.798-1.414-2.798L4.2 15.3" /></svg>`;
    }

    const bubble = document.createElement('div');
    bubble.className = 'max-w-[85%] rounded-2xl px-3 py-2.5 text-sm leading-relaxed ' +
      (isUser ? 'rounded-tr-sm bg-primary text-white' : 'rounded-tl-sm bg-white/8 text-white');

    let html = content
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\n/g, '<br>');
    bubble.innerHTML = html;

    wrapper.appendChild(avatar);
    wrapper.appendChild(bubble);

    if (isUser && quickSugg) quickSugg.remove();

    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function appendSystemMessage(text) {
    const el = document.createElement('div');
    el.className = 'text-center text-xs text-neutral/60 px-4 py-1 msg-animate';
    el.textContent = text;
    messagesEl.appendChild(el);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // ─── Botón de agendamiento ────────────────────────────────────────────────
  function appendScheduleButton() {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex items-start gap-2 msg-animate pl-9';

    const btn = document.createElement('button');
    btn.className = 'flex items-center gap-2 rounded-xl bg-primary px-4 py-2.5 text-sm font-medium text-white shadow-lg shadow-primary/30 transition hover:bg-blue-600 contact-button';
    btn.innerHTML = `
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      Agendar reunión con Alberto
    `;
    btn.addEventListener('click', () => {
      const modal = document.getElementById('contact-modal');
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      }
    });

    wrapper.appendChild(btn);
    messagesEl.appendChild(wrapper);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  // ─── Llamada a la API de OpenAI ───────────────────────────────────────────
  async function sendMessage(userText) {
    if (state.isLoading) return;
    stopAudio();

    appendMessage('user', userText);
    state.messages.push({ role: 'user', content: userText });

    state.isLoading = true;
    sendBtn.disabled = true;
    typingLabel.textContent = 'Pensando';
    typingEl.classList.remove('hidden');
    messagesEl.scrollTop = messagesEl.scrollHeight;

    try {
      const apiKey = window.__ABDEV_OPENAI_KEY__;
      if (!apiKey) throw new Error('NO_KEY');

      const response = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${apiKey}`,
        },
        body: JSON.stringify({
          model: 'gpt-4o-mini',
          messages: [
            { role: 'system', content: ABDEV_SYSTEM_PROMPT },
            ...state.messages,
          ],
          max_tokens: 300,
          temperature: 0.7,
        }),
      });

      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.error?.message || `HTTP ${response.status}`);
      }

      const data = await response.json();
      const assistantMsg = data.choices?.[0]?.message?.content || 'Lo siento, no pude procesar tu mensaje.';

      const shouldSchedule = assistantMsg.includes('AGENDAR_REUNION');
      const cleanMsg = assistantMsg.replace('AGENDAR_REUNION', '').trim();

      typingEl.classList.add('hidden');
      appendMessage('assistant', cleanMsg);
      state.messages.push({ role: 'assistant', content: cleanMsg });

      if (shouldSchedule) setTimeout(() => appendScheduleButton(), 300);

      // Hablar la respuesta con Cartesia
      typingLabel.textContent = 'Sintetizando voz';
      await speakWithCartesia(cleanMsg);

    } catch (err) {
      typingEl.classList.add('hidden');

      let errorMsg;
      if (err.message === 'NO_KEY') {
        errorMsg = 'Para activar el agente con IA, necesito una API key de OpenAI. Por ahora puedo mostrarte los servicios de ABDev: desarrollo web, agentes AI, sistemas de reservas y pagos. ¿Quieres agendar una llamada con Alberto? AGENDAR_REUNION';
      } else {
        errorMsg = `Tuve un problema técnico (${err.message}). Puedes contactar a Alberto directamente o agendar una reunión. AGENDAR_REUNION`;
      }

      const shouldSchedule = errorMsg.includes('AGENDAR_REUNION');
      const cleanMsg = errorMsg.replace('AGENDAR_REUNION', '').trim();

      appendMessage('assistant', cleanMsg);
      state.messages.push({ role: 'assistant', content: cleanMsg });

      if (shouldSchedule) setTimeout(() => appendScheduleButton(), 300);
      speakWithCartesia(cleanMsg);
    } finally {
      state.isLoading = false;
      sendBtn.disabled = false;
    }
  }
})();
</script>
