---
// AgentConfig.astro — Inyecta las API keys de forma segura desde variables de entorno de Vercel
// Variables requeridas en Vercel:
//   PUBLIC_OPENAI_API_KEY   → API key de OpenAI para el chat (GPT-4o-mini)
//   PUBLIC_CARTESIA_API_KEY → API key de Cartesia para síntesis de voz (Sonic-3)
const openaiKey   = import.meta.env.PUBLIC_OPENAI_API_KEY   ?? '';
const cartesiaKey = import.meta.env.PUBLIC_CARTESIA_API_KEY ?? '';
---

<script is:inline data-openai={openaiKey} data-cartesia={cartesiaKey}>
  (function() {
    var el = document.currentScript;
    window.__ABDEV_OPENAI_KEY__    = (el && el.getAttribute('data-openai'))   || null;
    window.__ABDEV_CARTESIA_KEY__  = (el && el.getAttribute('data-cartesia')) || null;
  })();
</script>
